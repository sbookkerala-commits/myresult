PORT=3000
HOST=0.0.0.0
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
USE_EMBEDDED_MONGO=true
RETENTION_DAYS=21
BACKUP_DIR=./backups

# Production (Render / Railway): copy server/.env.production and set:
# USE_EMBEDDED_MONGO=false
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/myresult?retryWrites=true&w=majority
# JWT_SECRET=<strong-random-secret>
